NODE_ENV=development
PORT=3000

# cp .env.example .env yapın; KULLANICI ve SIFRE yerine Atlas'taki bilgileri yazın.
# Şifrede @ # : gibi karakter varsa URL-encode edin veya Atlas'tan yeni şifre oluşturun.
MONGODB_URI=mongodb+srv://KULLANICI:SIFRE@cluster0.xxxxx.mongodb.net/inventory_db?retryWrites=true&w=majority&appName=Cluster0
# SRV / DNS hatası alırsanız Atlas'tan standart bağlantı dizesini kopyalayın.
# Yerel MongoDB: mongodb://127.0.0.1:27017/inventory_db

# Production (Vercel): izin verilen frontend origin'leri virgülle yazın.
# Örn: CORS_ORIGINS=https://stocker-frontend.vercel.app,https://custom-domain.com
# Boş bırakılırsa tüm origin'lere izin verilir (geliştirme için uygundur).
# CORS_ORIGINS=

# Geliştirme yardımcıları (üretimde kullanmayın):
# SKIP_DB=1            → MongoDB olmadan sunucu açılır (API DB hataları verir)
# DEV_ALLOW_DB_FAIL=1  → Bağlantı düşerse yine de dinlemeye geç
