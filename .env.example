NODE_ENV=development
PORT=3000
# cp .env.example .env yapın; aşağıdaki MONGODB_URI satırında KULLANICI ve SIFRE yerine
# Atlas → Database Access’te oluşturduğunuz kullanıcı adı ve şifreyi yazın (placeholder bırakmayın).
# Şifrede @ # : gibi karakter varsa URL-encode edin veya Atlas’tan yeni şifre oluşturun.
# Host kısmı (cluster0....mongodb.net) kendi cluster adresiniz olmalı.
MONGODB_URI=mongodb+srv://KULLANICI:SIFRE@cluster0.xxxxx.mongodb.net/inventory_db?retryWrites=true&w=majority&appName=Cluster0
# SRV / DNS hatası (querySrv ECONNREFUSED) alırsanız Atlas’ta aynı ekranda verilen
# "mongodb://host1:27017,host2:27017,..." standart bağlantı dizesini kullanın.
# Yerel MongoDB: mongodb://127.0.0.1:27017/inventory_db
#
# Geçici: Atlas’a bağlanamıyorsanız (IP whitelist vb.) sunucunun açılması için:
# SKIP_DB=1
# veya bağlantı denensin ama hata olsa bile süreç açılsın:
# DEV_ALLOW_DB_FAIL=1
# Üretimde kullanmayın; veritabanı olmadan API hata döner.
#
# npm: SKIP_DB için `npm run dev:safe` — Atlas hatasında devam için `npm run dev:fail`
